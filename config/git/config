[alias]
  b = branch
  ba = branch --all
  co = checkout
  d = -c delta.side-by-side=true diff
  dc = diff --cached
  dl = diff
  l = log --abbrev-commit --date=iso --graph --pretty=format:'%C(red)%h %C(yellow)%d%C(green)%cd %C(blue)%cn\n%C(reset)%s\n'
  lv = log --name-status --abbrev-commit --date=iso --graph --pretty=format:'%C(red)%h %C(yellow)%d%C(green)%cd %C(blue)%cn\n%C(reset)%s\n'
  s = status --branch --short
  delete-merged-branches = !git branch --merged | grep -v \\* | xargs -I % git branch -d %

[color]
  ui = true

[core]
  excludesfile = ~/.gitignore-global
  editor = /usr/bin/vim
  attributesfile = ~/.gitattributes
  quotepath = false
  pager = delta

[interactive]
    diffFilter = delta --color-only

[merge]
  ff = false
  conflictStyle = zdiff3
[pull]
  ff = only

[user]
  name = noboru-i
  email = noboru.ishikura@monstar-lab.com

[includeIf "gitdir:~/ghq/github.com/noboru-i/**"]
  path = ~/.gitconfig-noboru-i

[push]
  default = current
  autoSetupRemote = true
[fetch]
  prune = true

[ghq]
  root = ~/ghq

[credential]
	helper = osxkeychain
[init]
	defaultBranch = main
[http]
  postBuffer = 524288000
[credential "https://github.com"]
	helper =
	helper = !/etc/profiles/per-user/$USER/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/etc/profiles/per-user/$USER/bin/gh auth git-credential
